{
  "name": "douyin-creator-toolkit",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "smoke": "tsc --noEmit && npm run smoke:store && npm run smoke:ui && cargo test --manifest-path src-tauri/Cargo.toml --test deep_video_smoke && npm run smoke:tauri",
    "doctor:ffmpeg": "node scripts/doctor-ffmpeg.mjs",
    "doctor:ffmpeg:test": "node scripts/doctor-ffmpeg.test.mjs",
    "smoke:local-video": "npm run doctor:ffmpeg && cargo test --manifest-path src-tauri/Cargo.toml --test deep_video_smoke local_video_frame_evidence_smoke_writes_visual_artifacts -- --ignored --nocapture",
    "smoke:store": "node --experimental-strip-types src/stores/deepVideoRequest.test.ts",
    "smoke:tauri": "cargo test --manifest-path src-tauri/Cargo.toml --test tauri_gui_smoke",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
